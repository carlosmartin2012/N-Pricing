{
  "name": "n-pricing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"vite,api\" \"vite\" \"tsx server/index.ts\"",
    "dev:vite": "vite",
    "dev:api": "tsx server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test e2e/auth.spec.ts e2e/pricing-flow.spec.ts e2e/offline-pwa.spec.ts e2e/rbac.spec.ts",
    "typecheck": "tsc --noEmit",
    "build:edge": "node supabase/functions/pricing/build.mjs",
    "typecheck:edge": "npm run build:edge && deno check supabase/functions/pricing/index.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "verify": "npm run lint && npm run typecheck && npm run typecheck:edge && npm run check:sync && npm run check:data-quality && npm run check:security && npm run test && npm run build && npm run check:bundle",
    "verify:full": "npm run verify && npm run test:e2e",
    "check:sync": "npx tsx scripts/check-seed-schema-sync.ts",
    "check:data-quality": "npx tsx scripts/check-data-quality.ts",
    "check:security": "npx tsx scripts/check-dependency-audit.ts",
    "check:bundle": "npx tsx scripts/check-bundle-size.ts",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@react-oauth/google": "^0.12.1",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "@types/react-grid-layout": "^1.3.6",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "idb-keyval": "^6.2.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.563.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "^7.72.0",
    "react-is": "^19.2.4",
    "react-router": "^7.14.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.7.0",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.8.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
