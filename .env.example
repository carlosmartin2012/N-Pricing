# N-Pricing Environment Variables
# Copy this file to .env and fill in your values

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth (for @nfq.es domain login)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Gemini AI (for AI Assistant)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Demo credentials (optional — set to enable demo login)
VITE_DEMO_USER=demo
VITE_DEMO_PASS=change-this-password
VITE_DEMO_EMAIL=demo@nfq.es

# Pivot (PIVOT_PLAN.md §Bloque B)
# When true, MaturityLadder/CurrencyGap/NIISensitivity tabs render a "Moved to Alquid" panel.
VITE_NPRICING_DEPRECATE_ALM=false
VITE_ALQUID_BASE_URL=https://alquid.nfq.es

# AI Assistant refocus (ai-assistant-refocus.md)
VITE_AI_PRICING_COPILOT_ENABLED=true
VITE_AI_LOSS_CLASSIFIER_ENABLED=true
VITE_AI_NEGOTIATION_AGENT_ENABLED=false
VITE_AI_MODEL=gemini-2.0-flash
VITE_AI_TIMEOUT_MS=8000
VITE_AI_REDACT_PII=true
