# N-Pricing Environment Variables
# Copy this file to .env and fill in your values. Variables are grouped by
# concern; defaults noted as "unset -> <value>" are what the code assumes
# when the variable is absent. Everything prefixed with VITE_ is exposed
# to the browser bundle; everything else is server-only.

# =============================================================================
# Database (server)
# =============================================================================

# Required. Connection string for the Express server's pg.Pool.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/n_pricing

# TLS verification. Default `true` (enforced). Set to `false` ONLY for
# self-signed local dev instances; never in production.
# DB_REJECT_UNAUTHORIZED=true

# Optional custom CA bundle (PEM) for managed Postgres with internal cert.
# DATABASE_CA_CERT=

# Opt-in integration test suite. When set, enables the Postgres-backed
# tests in utils/__tests__/integration/ (otherwise auto-skipped).
# INTEGRATION_DATABASE_URL=

# =============================================================================
# Supabase (client + Edge Functions)
# =============================================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# Authentication
# =============================================================================

# Required in production. HMAC-SHA256 signing secret for the app's JWT.
# A dev fallback is used when unset + NODE_ENV != production so local
# development does not need this set. DO NOT ship an empty value.
# JWT_SECRET=

# SSO selection is currently IMPLICIT: presence of VITE_GOOGLE_CLIENT_ID
# routes sign-in through Google; absence falls back to the demo provider
# (which must only be used in non-prod). An explicit SSO_PROVIDER env var
# is tracked as a future improvement so the selection is not silent —
# see docs/integral-review-2026-04-18.md §2.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional. Restricts Google sign-in to a Google Workspace hosted domain
# (the `hd` claim). Prevents personal gmail accounts from signing in.
# GOOGLE_ALLOWED_HOSTED_DOMAIN=nfq.es

# =============================================================================
# Demo credentials (DEVELOPMENT ONLY)
# =============================================================================
# WARNING: VITE_* variables are embedded in the client bundle. Anything
# set here is visible to anyone who loads the app. Never set these in
# production — use Google SSO.
VITE_DEMO_USER=demo
VITE_DEMO_PASS=change-this-password-in-dev
VITE_DEMO_EMAIL=demo@nfq.es

# =============================================================================
# Multi-tenancy enforcement (Phase 0)
# =============================================================================

# Tenancy middleware rollout switch. Values: `off` (default, legacy) or `on`.
# When `on`, every entity-scoped route validates x-entity-id against
# entity_users before handlers run. Legacy routes (deals/audit/config) are
# also scope-aware as of 2026-04-18 — see review action #1.
# TENANCY_ENFORCE=off

# Strict mode for get_current_entity_id(). Values: `off` (default, legacy
# falls back to Default Entity) or `on` (raise on missing setting).
# Only flip to `on` AFTER TENANCY_ENFORCE=on has baked and the integration
# tests in utils/__tests__/integration/ pass against the target DB.
# TENANCY_STRICT=off

# =============================================================================
# Pricing engine (Edge Function + server)
# =============================================================================

# Mock fallback gate. DEFAULT IS `false` (not set = false). When `false`
# the Edge Function returns 400 configuration_incomplete listing missing
# sections — this is the CORRECT production behaviour. Set to `true` ONLY
# in dev/demo environments where falling back to seed data is acceptable.
# A regulatory pricing engine should never silently use mock data in prod.
# PRICING_ALLOW_MOCKS=false

# Git SHA written to pricing_snapshots.engine_version for each run. Wire
# this in CI (e.g. ENGINE_VERSION=$GITHUB_SHA). Unset -> 'dev-local'.
# ENGINE_VERSION=

# =============================================================================
# Governance
# =============================================================================

# Required in production. HMAC-SHA256 secret that signs committee dossiers.
# Rotating this invalidates verifyDossierSignature on all prior dossiers,
# so rotate behind a versioned key strategy if you do.
# DOSSIER_SIGNING_SECRET=

# =============================================================================
# Workers (opt-in background loops)
# =============================================================================

# Interval (ms) for the alert evaluator. Set to >= 1000 to enable; unset
# disables the worker entirely so local dev does not run background work.
# Recommended in prod: 30000 (30 s).
# ALERT_EVAL_INTERVAL_MS=

# Interval (ms) for the temporal approval escalation sweeper. Same opt-in
# pattern. Recommended in prod: 60000 (60 s). The POST /api/governance/
# escalations/sweep endpoint remains available for external cron triggers
# regardless of this value.
# ESCALATION_SWEEP_INTERVAL_MS=

# =============================================================================
# Integration adapters (Phase 4 + bootstrap 2026-04-18)
# =============================================================================

# CRM adapter selection. Values: `in-memory` (default) or `salesforce`.
# Falls back to in-memory with a console warning if required vars are
# absent, so a fresh deploy is never crashed by missing credentials.
# ADAPTER_CRM=in-memory
# SALESFORCE_INSTANCE_URL=https://your-org.my.salesforce.com
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_USERNAME=
# SALESFORCE_PASSWORD=
# SALESFORCE_PRIVATE_KEY_PEM=

# Market data adapter selection. Values: `in-memory` (default) or `bloomberg`.
# ADAPTER_MARKET_DATA=in-memory
# BLOOMBERG_APP_NAME=
# BLOOMBERG_SERVER_HOST=localhost
# BLOOMBERG_SERVER_PORT=8194
# BLOOMBERG_CURVE_TICKERS={"EUR":["EUSWE Curncy"],"USD":["USSWAP Curncy"]}

# =============================================================================
# Server binding + CORS
# =============================================================================

# Express bind port. Unset -> 3001. The Vite dev server is separately on
# :3000 (see vite.config.ts — :5000 is reserved by macOS AirPlay).
# PORT=3001

# Comma-separated list of allowed Origin headers. Unset falls back to
# localhost:{3000,5173,3001}. In production set to the deployed UI origin(s).
# ALLOWED_ORIGINS=https://your-deployment.example.com

# =============================================================================
# Pivot flags (PIVOT_PLAN.md §Bloque B)
# =============================================================================
# When true, MaturityLadder/CurrencyGap/NIISensitivity tabs render a
# "Moved to Alquid" panel.
VITE_NPRICING_DEPRECATE_ALM=false
VITE_ALQUID_BASE_URL=https://alquid.nfq.es

# =============================================================================
# AI Assistant refocus (ai-assistant-refocus.md)
# =============================================================================
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_AI_PRICING_COPILOT_ENABLED=true
VITE_AI_LOSS_CLASSIFIER_ENABLED=true
VITE_AI_NEGOTIATION_AGENT_ENABLED=false
VITE_AI_MODEL=gemini-2.0-flash
VITE_AI_TIMEOUT_MS=8000
VITE_AI_REDACT_PII=true
